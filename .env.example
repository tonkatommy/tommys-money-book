# Copy to .env and fill in. .env is gitignored — never commit real values.

# Used by docker-compose.yml for the Postgres container.
POSTGRES_USER=moneybook
POSTGRES_PASSWORD=change-me
POSTGRES_DB=moneybook

# Used by the app and Prisma when running on the host (npm run dev, migrations).
# Inside Docker the app gets its own DATABASE_URL from docker-compose.yml,
# pointing at host `db` instead of `localhost`.
DATABASE_URL="postgresql://moneybook:change-me@localhost:5432/moneybook"
